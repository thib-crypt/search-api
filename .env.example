# ---- App ----
ENVIRONMENT=development
LOG_LEVEL=INFO
# External port exposed by the API container (change if 8000 is already taken).
API_PORT=8000

# ---- Auth (optional) ----
# Set to true to require an API key on every request.
AUTH_ENABLED=false
# Comma-separated list of accepted keys (used only when AUTH_ENABLED=true).
API_KEYS=

# ---- Hardening ----
RATE_LIMIT_ENABLED=false
RATE_LIMIT_RPM=120
# Set to true only when behind a trusted reverse-proxy that sets X-Forwarded-For.
TRUSTED_PROXY=false
SECURITY_HEADERS=true
# Comma-separated allowed CORS origins ("*" allows all).
CORS_ORIGINS=*

# ---- SearXNG ----
# Inside docker-compose use the service name; for local dev use http://localhost:8080
SEARXNG_URL=http://searxng:8080
SEARXNG_TIMEOUT=15
# Max pooled HTTP connections kept open to SearXNG.
SEARXNG_MAX_CONNECTIONS=64

# ---- Search cache ----
# Memoizes identical queries for a short window (big win for deep research).
SEARCH_CACHE_ENABLED=true
SEARCH_CACHE_TTL=300
SEARCH_CACHE_MAX_SIZE=512

# ---- Jobs ----
# Seconds a finished job (and its result) is kept in memory before eviction.
JOB_RETENTION_SECONDS=3600

# ---- LLM ----
# litellm provider strings: openai/..., anthropic/..., gemini/..., openrouter/...
LLM_MODEL=openai/gpt-4o-mini
# Optional dedicated model for report writing (falls back to LLM_MODEL).
LLM_REPORT_MODEL=
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096

# ---- Provider API keys (read directly by litellm; set only what you use) ----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# ---- Crawl ----
CRAWL_MAX_CONCURRENCY=5
CRAWL_TIMEOUT=30

# ---- Research ----
RESEARCH_DEFAULT_BREADTH=4
RESEARCH_DEFAULT_DEPTH=2
RESEARCH_CONCURRENCY=2
# Max seconds for a synchronous /v1/research call (0 = no limit). Use background=true for long queries.
RESEARCH_SYNC_TIMEOUT=600

# ---- SearXNG container secret (generate with: openssl rand -hex 32) ----
SEARXNG_SECRET=change-me-please
