# ---- App ----
ENVIRONMENT=development
LOG_LEVEL=INFO
# External port exposed by the API container (change if 8000 is already taken).
API_PORT=8000

# ---- Auth (optional) ----
# Set to true to require an API key on every request.
AUTH_ENABLED=false
# Comma-separated list of accepted keys (used only when AUTH_ENABLED=true).
API_KEYS=

# ---- Hardening ----
RATE_LIMIT_ENABLED=false
RATE_LIMIT_RPM=120
SECURITY_HEADERS=true
# Comma-separated allowed CORS origins ("*" allows all).
CORS_ORIGINS=*

# ---- SearXNG ----
# Inside docker-compose use the service name; for local dev use http://localhost:8080
SEARXNG_URL=http://searxng:8080
SEARXNG_TIMEOUT=15

# ---- LLM ----
# litellm provider strings: openai/..., anthropic/..., gemini/..., openrouter/...
LLM_MODEL=openai/gpt-4o-mini
# Optional dedicated model for report writing (falls back to LLM_MODEL).
LLM_REPORT_MODEL=
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096

# ---- Provider API keys (read directly by litellm; set only what you use) ----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# ---- Crawl ----
CRAWL_MAX_CONCURRENCY=5
CRAWL_TIMEOUT=30

# ---- Research ----
RESEARCH_DEFAULT_BREADTH=4
RESEARCH_DEFAULT_DEPTH=2
RESEARCH_CONCURRENCY=2

# ---- SearXNG container secret (generate with: openssl rand -hex 32) ----
SEARXNG_SECRET=change-me-please
